# whisper-stt-bench configuration
WHISPER_BENCH_WHISPER_MODEL=distil-large-v3
WHISPER_BENCH_WHISPER_DEVICE=auto
WHISPER_BENCH_WHISPER_COMPUTE_TYPE=float16
WHISPER_BENCH_CORPUS_DIR=.runtime/corpus
WHISPER_BENCH_RESULTS_DIR=.runtime/results
WHISPER_BENCH_LOG_LEVEL=INFO
WHISPER_BENCH_PORT=5000

# Auth — set token directly or use AWS Secrets Manager
WHISPER_BENCH_BEARER_TOKEN=
WHISPER_BENCH_AWS_SECRET_NAME=
WHISPER_BENCH_AWS_REGION=us-east-1
